# Variáveis de Ambiente - Template
# Copie este arquivo para .env e preencha os valores
# IMPORTANTE: .env NÃO deve ser commitado (está em .gitignore)

# Ambiente
NODE_ENV=development
DEBUG=false

# Servidor
PORT=3000
LOG_LEVEL=info

# APIs Externas
IKRO_API_BASE=https://adm.ikro.com.br/api
NOTUS_API_URL=https://catalogo.notus.ind.br/conversor/produtos.json
REQUEST_TIMEOUT=10000

# CORS (separado por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Segurança (opcional)
# ADMIN_PASSWORD=sua_senha_segura_aqui
# JWT_SECRET=sua_chave_jwt_aqui

# Performance
CACHE_TTL=3600000
MAX_REQUESTS_PER_MINUTE=100

# Monitoring (opcional - para Sentry, LogRocket, etc)
# SENTRY_DSN=https://xxx@sentry.io/xxx
